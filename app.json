{
  "expo": {
    "name": "Budget",
    "slug": "budget-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "budget",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourcompany.budgetapp"
    },
    "android": {
      "package": "com.yourcompany.budgetapp"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
