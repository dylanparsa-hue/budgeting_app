# ════════════════════════════════════════════════════════
#  Budget App — Server Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control!
# ════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────
# Local dev (via Docker Compose):
DATABASE_URL=postgresql://budget_user:your_strong_password@localhost:5432/budget_app

# Production: add ?sslmode=require for TLS enforcement
# DATABASE_URL=postgresql://user:pass@your-pg-host:5432/budget_app?sslmode=require

# ── JWT Secrets ──────────────────────────────────────────
# REQUIRED — server will refuse to start without these.
# Generate secure values:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64_different_value
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Security ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
# In production, restrict to your app's domain or IP:
CORS_ORIGIN=*

# ── Optional: SSL for DB connection (production) ─────────
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=/path/to/ca-certificate.crt

# ── Optional: DB connection pool size ────────────────────
# DB_POOL_MAX=20
