# ════════════════════════════════════════════════════════
#  Budget App — Docker Environment Variables
#  Copy this file to .env.docker and fill in real values.
#  NEVER commit .env.docker to version control!
# ════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=budget_app
POSTGRES_USER=budget_user
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ── API Server ───────────────────────────────────────────
API_PORT=3001
NODE_ENV=production

# ── JWT Secrets ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Or:            openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64_different_value
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Security ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
# In production, restrict to your app's domain or IP:
CORS_ORIGIN=*
